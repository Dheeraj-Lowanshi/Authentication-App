package com.auth_app.config;

import io.swagger.v3.oas.annotations.OpenAPIDefinition;
import io.swagger.v3.oas.annotations.enums.SecuritySchemeType;
import io.swagger.v3.oas.annotations.info.Contact;
import io.swagger.v3.oas.annotations.info.Info;
import io.swagger.v3.oas.annotations.security.SecurityRequirement;
import io.swagger.v3.oas.annotations.security.SecurityScheme;
import org.springframework.context.annotation.Configuration;

@Configuration
@OpenAPIDefinition(
        info = @Info(
            title= "Auth Application build by Dheeraj Lowanshi.",
                description = "Generic auth app that can be used for any purpose.",
                contact = @Contact(
                    name = "Dheeraj Lowanshi",
                    url = "https://github.com/dheerajlowanshi",
                    email = "dheerajlowanshi04@gmail.com"
                ),
                version = "1.0",
                summary = "This app is very useful for authentication and authorization."
        ),
        security ={
                @SecurityRequirement(
                        name = "bearerAuth"
                )
        }
)
@SecurityScheme(
        name = "bearerAuth",
        type = SecuritySchemeType.HTTP,
        bearerFormat = "JWT",
        scheme = "bearer"  
)
public class APIDocConfig {


}
